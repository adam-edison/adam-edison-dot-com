# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Resend API key used for sending contact-form emails
RESEND_API_KEY=your-resend-api-key-here

# Sender email address for contact form submissions
FROM_EMAIL=your-contact@email.com

# Recipient email address for contact form submissions
TO_EMAIL=your-inbox@email.com

# Whether to actually send email through Resend
# Set to 'true' to enable email sending; any other value disables sending
SEND_EMAIL_ENABLED=true

# Display name shown in the From header of contact form emails
EMAIL_SENDER_NAME=Personal Website Contact Form

# Display name shown in the To header of contact form emails
EMAIL_RECIPIENT_NAME=Adam Edison

# Cloudflare Turnstile site key used by the client-side widget
# Testing values (https://developers.cloudflare.com/turnstile/troubleshooting/testing/):
#   1x00000000000000000000AA  visible widget, always passes
#   2x00000000000000000000AB  visible widget, always fails
#   3x00000000000000000000FF  visible widget, always forces an interactive challenge
#   1x00000000000000000000BB  invisible widget, always passes
#   2x00000000000000000000BB  invisible widget, always fails
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Turnstile secret key used for server-side token verification
# Testing values (https://developers.cloudflare.com/turnstile/troubleshooting/testing/):
#   1x0000000000000000000000000000000AA  always passes verification
#   2x0000000000000000000000000000000AA  always fails verification
#   3x0000000000000000000000000000000AA  always returns "token already spent"
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Upstash Redis REST URL used for rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io

# Upstash Redis REST token used for authentication
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Prefix applied to every Redis key (used to namespace dev/prod/test data)
REDIS_PREFIX=personal-website

# Number of contact-form requests allowed per IP within the rate-limit window
RATE_LIMIT_REQUESTS=2

# Time window for per-IP rate limiting (e.g., '10 s', '30 m', '1 h')
RATE_LIMIT_WINDOW=30 m

# Total number of contact-form requests allowed globally within the window
GLOBAL_RATE_LIMIT_REQUESTS=10

# Time window for global rate limiting (e.g., '10 s', '30 m', '1 h')
GLOBAL_RATE_LIMIT_WINDOW=1 h

# GitHub profile URL shown in the site's social links
NEXT_PUBLIC_GITHUB_URL=https://github.com/adam-edison

# LinkedIn profile URL shown in the site's social links
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/adam-edison-software/

# Repository URL used by the "View Source Code" link
NEXT_PUBLIC_REPO_URL=https://github.com/adam-edison/adam-edison-dot-com

# Sentry DSN for server-side error reporting (Pages Router API routes, instrumentation)
# Leave unset locally; production builds require it (validated at build time)
SENTRY_DSN=

# Sentry DSN exposed to the browser bundle for client-side error reporting
# Typically the same value as SENTRY_DSN
NEXT_PUBLIC_SENTRY_DSN=

# Sentry CLI auth token used at build time to upload source maps (optional)
SENTRY_AUTH_TOKEN=

# Sentry organization slug used at build time to upload source maps (optional)
SENTRY_ORG=

# Sentry project slug used at build time to upload source maps (optional)
SENTRY_PROJECT=
